COMPOSE_PROJECT_NAME=hackatontransgod

# Puertos publicados solamente por docker-compose.local.yml
APP_PORT=8080
POSTGRES_LOCAL_PORT=5433
OLLAMA_LOCAL_PORT=11435

# PostgreSQL. Cambiar completamente en Dokploy.
POSTGRES_DB=BaseDatosPozoArenilla
POSTGRES_USER=postgres
POSTGRES_PASSWORD=solo_local_cambiar_123
POSTGRES_CONN_MAX_AGE=60

# Django local dentro de Docker.
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=django-insecure-solo-local-cambiar-antes-de-produccion-8mD3kP9xQ2
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,davidlent.shop,www.davidlent.shop
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,https://davidlent.shop,https://www.davidlent.shop
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,https://davidlent.shop,https://www.davidlent.shop
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_COOKIES=False
DJANGO_HSTS_SECONDS=0
DJANGO_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_HSTS_PRELOAD=False
SESION_INACTIVIDAD_MINUTOS=30
ADMIN_SESION_INACTIVIDAD_MINUTOS=30

# Se crea solamente la primera vez. Cambiar estos datos en Dokploy.
DJANGO_SUPERUSER_EMAIL=admin@local.test
DJANGO_SUPERUSER_NAME="Administrador local"
DJANGO_SUPERUSER_PASSWORD=solo-local-admin-123

# Ollama y Gunicorn.
OLLAMA_MODELO_GUIA=deepseek-r1:8b
OLLAMA_TIMEOUT_SEGUNDOS=180
OLLAMA_KEEP_ALIVE=2m
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=240
